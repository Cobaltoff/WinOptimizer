<Window
    x:Class="WinOptimizer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:WinOptimizer"
    mc:Ignorable="d"
    Title="WinOptimizer — Sistem Optimizasyon Aracı"
    Height="750" Width="1150"
    MinHeight="600" MinWidth="900"
    WindowStartupLocation="CenterScreen"
    Background="#0f0f1a">

    <Window.Resources>
        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a0a0c0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1e1e3a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2a2a4a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#5c5cff"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#7070ff"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4040cc"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#333355"/>
                                <Setter Property="Foreground" Value="#666688"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1e1e3a"/>
            <Setter Property="Foreground" Value="#a0a0c0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3a3a5a"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2a2a4a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <!-- ÜST BAR -->
        <Border Grid.Row="0" Background="#13132a"
                BorderBrush="#2a2a4a" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="22" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="WinOptimizer" FontSize="18" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <Border Background="#5c5cff" CornerRadius="4" Padding="6,2"
                            Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="v1.0" FontSize="10" Foreground="White"/>
                    </Border>

                    <!-- İMZA  -->
                    <TextBlock Text="Created By KadirKaan" 
                               Foreground="#8888aa" 
                               FontSize="12" 
                               Margin="15,0,0,0" 
                               VerticalAlignment="Center" 
                               FontStyle="Italic"
                               Opacity="0.8"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                           Foreground="#6666aa" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Dil seçici -->
                    <Border Background="#1e1e3a" CornerRadius="8"
                            BorderBrush="#3a3a5a" BorderThickness="1"
                            Margin="0,0,8,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="🇹🇷" FontSize="16"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="8,5"
                                    Click="LangTR_Click" ToolTip="Türkçe"/>
                            <Border Width="1" Background="#3a3a5a" Margin="0,4"/>
                            <Button Content="🇬🇧" FontSize="16"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="8,5"
                                    Click="LangEN_Click" ToolTip="English"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="BtnRescan"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ScanSystemCommand}"
                            Margin="0,0,8,0"/>
                    <Button x:Name="BtnAbout"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="AboutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ANA İÇERİK -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SOL MENÜ -->
            <Border Grid.Column="0" Background="#13132a"
                    BorderBrush="#2a2a4a" BorderThickness="0,0,1,0">
                <StackPanel Margin="8,12">
                    <Border Background="#1a1a35" CornerRadius="8"
                            Padding="12,10" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="LblSystemStatus"
                                       Foreground="#6666aa"
                                       FontSize="10" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding ScanMessage}"
                                       Foreground="#a0a0c0" FontSize="11"
                                       TextWrapping="Wrap"/>
                            <ProgressBar Margin="0,8,0,0" Height="3"
                                         Value="{Binding ProgressValue}" Maximum="100"
                                         Background="#2a2a4a" Foreground="#5c5cff"
                                         Visibility="{Binding IsApplying,
                                             Converter={StaticResource BoolToVisConverter}}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="LblCategories"
                               Foreground="#4444aa"
                               FontSize="10" FontWeight="Bold" Margin="8,0,0,8"/>

                    <ItemsControl ItemsSource="{Binding Categories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource CategoryButtonStyle}"
                                        Command="{Binding DataContext.SelectCategoryCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Name}"
                                        Margin="0,1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" FontSize="16"
                                                   Width="22" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- SAĞ ALAN -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Kategori başlık -->
                <Border Grid.Row="0" Background="#13132a" Padding="20,12"
                        BorderBrush="#2a2a4a" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding SelectedCategory}"
                                   Foreground="White" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="BtnSelectRecommended"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SelectRecommendedCommand}"
                                    FontSize="12" Padding="12,7" Margin="0,0,8,0"/>
                            <Button x:Name="BtnToggleAll"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ToggleSelectAllCommand}"
                                    FontSize="12" Padding="12,7"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Optimizasyon listesi -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <StackPanel Visibility="{Binding IsScanning,
                                        Converter={StaticResource BoolToVisConverter}}"
                                    HorizontalAlignment="Center" Margin="0,80">
                            <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="LblScanning"
                                       Foreground="#6666aa" FontSize="14"
                                       HorizontalAlignment="Center" Margin="0,12,0,0"/>
                            <TextBlock Text="{Binding ScanMessage}"
                                       Foreground="#4444aa" FontSize="12"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding CurrentItems}"
                                      Visibility="{Binding IsScanning,
                                          Converter={StaticResource InverseBoolToVisConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#13132a" BorderBrush="#2a2a4a"
                                            BorderThickness="1" CornerRadius="10"
                                            Padding="16,12" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      IsEnabled="{Binding IsEnabled}"
                                                      VerticalAlignment="Top"
                                                      Margin="0,2,14,0"/>

                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="White"
                                                               FontSize="13" FontWeight="SemiBold"/>
                                                    <Border Background="#1a3a1a" BorderBrush="#2a5a2a"
                                                            BorderThickness="1" CornerRadius="4"
                                                            Padding="6,1" Margin="8,0,0,0"
                                                            Visibility="{Binding IsRecommended,
                                                                Converter={StaticResource BoolToVisConverter}}">
                                                        <TextBlock x:Name="LblRecommended"
                                                                   Text="{Binding DataContext.RecommendedLabel,
                                                                       RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   Foreground="#44cc44" FontSize="9"/>
                                                    </Border>
                                                    <Border Background="#1a2a3a" BorderBrush="#2a4a5a"
                                                            BorderThickness="1" CornerRadius="4"
                                                            Padding="6,1" Margin="8,0,0,0"
                                                            Visibility="{Binding IsApplied,
                                                                Converter={StaticResource BoolToVisConverter}}">
                                                        <TextBlock Text="{Binding DataContext.AppliedLabel,
                                                                       RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   Foreground="#44aacc" FontSize="9"/>
                                                    </Border>
                                                </StackPanel>

                                                <TextBlock Text="{Binding ShortDescription}"
                                                           Foreground="#7070aa" FontSize="12"
                                                           Margin="0,3,0,0"/>

                                                <Border Background="#0a0a1a" BorderBrush="#3a3a5a"
                                                        BorderThickness="1" CornerRadius="6"
                                                        Padding="10,8" Margin="0,8,0,0"
                                                        Visibility="{Binding IsSelected,
                                                            Converter={StaticResource BoolToVisConverter}}">
                                                    <StackPanel>
                                                        <Grid Margin="0,0,0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding DataContext.LblWhatItDoes,
                                                                           RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="#5555aa" FontSize="11"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding WhatItDoes}"
                                                                       Foreground="#9090cc" FontSize="11"
                                                                       TextWrapping="Wrap"/>
                                                        </Grid>
                                                        <Grid Margin="0,0,0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding DataContext.LblBenefit,
                                                                           RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="#335533" FontSize="11"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Benefit}"
                                                                       Foreground="#66aa66" FontSize="11"
                                                                       TextWrapping="Wrap"/>
                                                        </Grid>
                                                        <Grid Margin="0,0,0,4"
                                                              Visibility="{Binding RiskDescription,
                                                                  Converter={StaticResource StringToVisConverter}}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding DataContext.LblRisk,
                                                                           RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="#aa6633" FontSize="11"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding RiskDescription}"
                                                                       Foreground="#cc8844" FontSize="11"
                                                                       TextWrapping="Wrap"/>
                                                        </Grid>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding DataContext.LblReversible,
                                                                           RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       Foreground="#5555aa" FontSize="11"/>
                                                            <TextBlock Grid.Column="1" FontSize="11">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text"
                                                                                Value="{Binding DataContext.LblYes,
                                                                                    RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                        <Setter Property="Foreground" Value="#66aa66"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsReversible}" Value="False">
                                                                                <Setter Property="Text"
                                                                                        Value="{Binding DataContext.LblNo,
                                                                                            RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                                <Setter Property="Foreground" Value="#cc4444"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2"
                                                       VerticalAlignment="Top"
                                                       FontSize="18" Margin="10,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="🟢"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Risk}" Value="Low">
                                                                <Setter Property="Text" Value="🟡"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Risk}" Value="Medium">
                                                                <Setter Property="Text" Value="🟠"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Risk}" Value="High">
                                                                <Setter Property="Text" Value="🔴"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Sonuç paneli -->
                <Border Grid.Row="2" Background="#0a1a0a" BorderBrush="#2a5a2a"
                        BorderThickness="0,1,0,0" Padding="20,12"
                        Visibility="{Binding ShowResultPanel,
                            Converter={StaticResource BoolToVisConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding ResultSummary}"
                                       Foreground="#44cc44" FontSize="13"/>
                            <TextBlock x:Name="LblRestartWarning"
                                       Foreground="#cc8844" FontSize="12" Margin="0,4,0,0"
                                       Visibility="{Binding RequiresRestart,
                                           Converter={StaticResource BoolToVisConverter}}"/>
                        </StackPanel>
                        <Button x:Name="BtnSaveLog" Grid.Column="1"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding SaveLogCommand}" FontSize="12"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ALT BAR -->
        <Border Grid.Row="2" Background="#13132a"
                BorderBrush="#2a2a4a" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           Foreground="#4444aa" FontSize="11"
                           FontFamily="Consolas" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <Button x:Name="BtnSelectRecommended2" Grid.Column="1"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding SelectRecommendedCommand}"
                        Margin="8,0"/>

                <Button x:Name="BtnApply" Grid.Column="2"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding ApplySelectedCommand}"
                        Margin="8,0"/>

                <Button x:Name="BtnRestore" Grid.Column="3"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="RestoreButton_Click"
                        Margin="8,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>